---
import HamburgerMenu from "./HamburgerMenu.tsx";

interface Props {
  currentPage: "home" | "about";
}
const { currentPage } = Astro.props;
---

<header
  class="sticky top-0 z-50 w-full border-b border-white/20 bg-bg-0/92 backdrop-blur-md"
>
  <div
    class="industrial-container grid min-h-[68px] grid-cols-[1fr_auto] items-center gap-4 md:grid-cols-[1fr_auto_1fr]"
  >
    <a
      href="/"
      class="group inline-flex min-h-11 items-center gap-3 focus-industrial"
    >
      <span
        class="grid h-10 w-10 place-items-center border border-brand bg-brand text-[0.7rem] font-black tracking-[0.12em] text-white"
        aria-hidden="true">AI</span
      >
      <span class="flex flex-col leading-none">
        <span class="animated-gradient-logo text-xl uppercase tracking-normal"
          >AI News</span
        >
        <span class="micro-label hidden text-text-2 sm:block">News feed</span>
      </span>
    </a>

    <nav
      class="hidden items-center border-x border-white/20 md:flex"
      aria-label="Primary navigation"
    >
      <a
        href="/"
        class={`micro-label inline-flex min-h-[68px] items-center border-r border-white/20 px-7 transition-colors ${currentPage === "home" ? "bg-brand text-white" : "text-text-2 hover:bg-white/10 hover:text-white"}`}
        aria-current={currentPage === "home" ? "page" : undefined}
      >
        [ Home ]
      </a>
      <a
        href="/about/"
        class={`micro-label inline-flex min-h-[68px] items-center px-7 transition-colors ${currentPage === "about" ? "bg-brand text-white" : "text-text-2 hover:bg-white/10 hover:text-white"}`}
        aria-current={currentPage === "about" ? "page" : undefined}
      >
        [ About ]
      </a>
    </nav>

    <div
      class="hidden justify-self-end text-right font-mono text-[0.68rem] uppercase leading-tight tracking-[0.08em] text-text-2 md:block"
    >
      <span class="block text-white">Updated hourly</span>
      <span class="block">RSS and source feeds</span>
    </div>

    <div class="flex justify-end md:hidden">
      <HamburgerMenu client:media="(max-width: 767px)" />
    </div>
  </div>
</header>
