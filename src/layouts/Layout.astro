---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  canonical: string;
  keywords?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  robots?: string;
  currentPage?: "home" | "about" | "models" | "digest" | "none";
  bodyClass?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  preloadImage?: string;
  preloadImages?: string[];
}

const {
  title,
  description,
  canonical,
  keywords,
  ogImage = "https://ai-news.helloworldfirm.com/ai-news-favicon-512x512.png",
  ogImageAlt = "AI News Hub logo",
  ogType = "website",
  robots = "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1",
  currentPage = "none",
  bodyClass = "bg-bg-0 text-text-1 font-sans min-h-screen flex flex-col",
  structuredData,
  preloadImage,
  preloadImages = [],
} = Astro.props;

const jsonLdBlocks = structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [];
const headerLogoImage = "/ai_news_logo_assets/ai-news-logo-normal-transparent.png";
const footerLogoImage = "/ai_news_logo_assets/ai-news-logo-footer-512w.png";
const imagePreloads = Array.from(new Set([headerLogoImage, footerLogoImage, preloadImage, ...preloadImages].filter(Boolean)));
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={robots} />
    <meta name="author" content="Jonathan R. Reed" />
    <meta name="application-name" content="AI News Hub" />
    <meta name="apple-mobile-web-app-title" content="AI News Hub" />
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="AI News Hub" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="AI News Hub" href="/feed.xml" />
    <link rel="alternate" type="application/json" title="AI News Hub" href="/articles.json" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.helloworldfirm.com" />
    <link rel="preconnect" href="https://fonts.helloworldfirm.com" crossorigin />
    {imagePreloads.map((href) => <link rel="preload" href={href} as="image" />)}
    <link rel="preload" href="/global-font.css" as="style" />
    <link rel="preload" href="/global-animated-gradient.css" as="style" />
    <link rel="stylesheet" href="/global-font.css" />
    <link rel="stylesheet" href="/global-animated-gradient.css" />
    <noscript set:html={`<style>.reveal-stagger > * { opacity: 1 !important; transform: none !important; }</style>`}></noscript>
    <link
      rel="preload"
      href="https://fonts.helloworldfirm.com/NebulaSans-Book.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="https://fonts.helloworldfirm.com/NebulaSans-BoldItalic.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {jsonLdBlocks.map((block) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(block).replace(/</g, "\\u003c")} />
    ))}
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header currentPage={currentPage} />
    <slot />
    <Footer />
    <script is:inline>
      (function(){
        if(typeof window==='undefined')return;
        var els=document.querySelectorAll('.reveal-stagger');
        if(!els.length)return;
        var ro=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');ro.unobserve(e.target);}});},{threshold:0.08,rootMargin:'0px 0px -40px 0px'});
        els.forEach(function(el){ro.observe(el);});
      })();
    </script>
  </body>
</html>
