---
import Header from '../components/Header.astro';
import Footer from "../components/Footer.astro";
import FaqDropdown from '../components/FaqDropdown.tsx';
import NeuralGrid from '../components/NeuralGrid.tsx';
import { companies } from '../lib/companyCatalog.js';
import type { CompanyEntry } from '../lib/companyCatalog.js';

const siteUrl = "https://ai-news.helloworldfirm.com";
const canonicalUrl = `${siteUrl}/about`;
const title = "About AI News Hub";
const description = "AI News Hub collects AI articles from RSS and Atom feeds.";
const keywords = "About AI News Hub, AI news aggregator, AI RSS feeds, Hello.World Consulting";
const socialImage = "https://img.helloworldfirm.com/logos/512x512-logo.avif";
const socialImageAlt = "AI News Hub galaxy-inspired logo";
const creatorImage = "https://img.helloworldfirm.com/personal/jonathan.avif";
const sourceCompanies: CompanyEntry[] = companies.filter((company: CompanyEntry) => company.name !== 'All');
const creator = {
  "@type": "Person",
  name: "Jonathan R Reed",
  url: "https://jonathanrreed.com",
  image: creatorImage,
  jobTitle: "Software builder",
};
const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: title,
  url: canonicalUrl,
  description,
  author: creator,
  creator,
  publisher: {
    "@type": "Organization",
    name: "Hello.World Consulting",
    url: "https://helloworldfirm.com",
    logo: {
      "@type": "ImageObject",
      url: socialImage
    }
  },
  mainEntityOfPage: canonicalUrl,
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: siteUrl
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "About",
        item: canonicalUrl
      }
    ]
  }
};
---
<html lang="en">
  <head>
    <title>{title}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="author" content="Jonathan R Reed" />
    <meta name="application-name" content="AI News Hub" />
    <meta name="apple-mobile-web-app-title" content="AI News Hub" />
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="AI News Hub" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="author" href="https://jonathanrreed.com" />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <link rel="apple-touch-icon" href="/favicon.webp" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="dns-prefetch" href="https://img.helloworldfirm.com" />
    <link rel="preconnect" href="https://fonts.helloworldfirm.com" />
    <link rel="preconnect" href="https://fonts.helloworldfirm.com" crossorigin />
    <link rel="preload" href="/global-font.css" as="style" />
    <link rel="preload" href="/global-animated-gradient.css" as="style" />
    <link rel="stylesheet" href="/global-font.css" />
    <link rel="stylesheet" href="/global-animated-gradient.css" />
    <link rel="preload" href="https://fonts.helloworldfirm.com/NebulaSans-Book.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="https://fonts.helloworldfirm.com/NebulaSans-BoldItalic.woff2" as="font" type="font/woff2" crossorigin />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  </head>
  <body class="bg-bg-0 text-text-1 font-sans min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <NeuralGrid client:visible />
    <Header currentPage="about" />
    <main id="main-content" class="industrial-shell flex-1">
      <section class="industrial-container py-24 md:py-36">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_380px]">
          <div class="max-w-5xl">
            <p class="micro-label mb-5 text-brand">[ About ]</p>
            <h1 class="macro-heading max-w-5xl">AI News Hub</h1>
            <p class="mt-8 max-w-3xl text-xl leading-relaxed text-text-2">
              AI News Hub collects articles from RSS and Atom feeds for major AI labs and tools.
            </p>
          </div>
          <aside class="industrial-border h-fit p-6">
            <p class="micro-label mb-6 text-text-2">[ Made by ]</p>
            <div class="mb-8 grid grid-cols-[72px_minmax(0,1fr)] items-center gap-4 border-b border-white/15 pb-6">
              <img
                src={creatorImage}
                alt="Jonathan R Reed"
                width="144"
                height="144"
                class="h-[72px] w-[72px] border border-white/20 object-cover grayscale contrast-125"
                loading="eager"
                decoding="async"
              />
              <div>
                <h2 class="text-2xl font-black uppercase leading-none text-white">
                  Jonathan R Reed
                </h2>
                <a
                  href="https://jonathanrreed.com"
                  target="_blank"
                  rel="author noopener noreferrer"
                  class="mt-2 inline-block font-mono text-xs uppercase tracking-[0.08em] text-text-2 underline decoration-brand decoration-2 underline-offset-4 hover:text-white"
                >
                  jonathanrreed.com
                </a>
              </div>
            </div>
            <p class="micro-label mb-8 text-text-2">[ Sources ]</p>
            <ul class="space-y-3 font-mono text-sm uppercase tracking-[0.08em] text-white">
              {sourceCompanies.map((company, index) => (
                <li class={index === sourceCompanies.length - 1 ? '' : 'border-b border-white/15 pb-3'}>
                  {company.name}
                </li>
              ))}
            </ul>
          </aside>
        </div>
      </section>
      <section class="industrial-container pb-24 md:pb-36">
        <div class="industrial-grid">
          <article class="col-span-12 p-6 md:col-span-4 md:p-8">
            <p class="micro-label mb-8 text-text-2">[ Sources ]</p>
            <h2 class="mb-4 text-3xl font-black uppercase leading-none text-white">
              Feeds
            </h2>
            <p class="leading-relaxed text-text-2">
              Articles come from RSS and Atom feeds.
            </p>
          </article>
          <article class="col-span-12 p-6 md:col-span-4 md:p-8">
            <p class="micro-label mb-8 text-text-2">[ Updates ]</p>
            <h2 class="mb-4 text-3xl font-black uppercase leading-none text-white">
              Hourly
            </h2>
            <p class="leading-relaxed text-text-2">
              The feed updates hourly.
            </p>
          </article>
          <article class="col-span-12 p-6 md:col-span-4 md:p-8">
            <p class="micro-label mb-8 text-text-2">[ Project ]</p>
            <h2 class="mb-4 text-3xl font-black uppercase leading-none text-white">
              Open source
            </h2>
            <p class="leading-relaxed text-text-2">
              See the project on GitHub or visit
              <a href="https://jonathanrreed.com/projects/" target="_blank" rel="noopener noreferrer" class="text-white underline decoration-brand decoration-2 underline-offset-4 hover:text-brand-hover">JonathanRReed.com</a>.
            </p>
          </article>
        </div>
        <a href="/" class="signal-button mt-10">Back to home</a>
      </section>
      <div class="industrial-container pb-24">
        <FaqDropdown client:idle />
      </div>
    </main>
    <Footer />
  </body>
</html>
