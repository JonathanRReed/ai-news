---
import { URL } from "node:url";
import Layout from "../../layouts/Layout.astro";
import providerArticles from "../../../public/data/provider-articles.json";
import { companyLogoAlt, resolveCompanyLogo } from "../../lib/companyCatalog.js";
import { deriveTopics, topicLabel, deriveEntities, readingMinutes } from "../../lib/articleTags.js";
import type { Article } from "../../types/article.js";

export function getStaticPaths() {
  const articles = providerArticles as Article[];
  return articles.map((article) => ({ params: { id: article.id }, props: { article } }));
}

const { article } = Astro.props as { article: Article };
const allArticles = providerArticles as Article[];
const siteUrl = "https://ai-news.helloworldfirm.com";
const canonicalUrl = `${siteUrl}/article/${article.id}/`;
const socialImage = `${siteUrl}/ai-news-favicon-512x512.png`;

function safeUrl(url: string): string {
  try {
    const parsed = new URL(url);
    return parsed.protocol === "https:" || parsed.protocol === "http:" ? parsed.toString() : "";
  } catch {
    return "";
  }
}
const originalUrl = safeUrl(article.url);
const domain = originalUrl ? new URL(originalUrl).hostname.replace(/^www\./, "") : "";
const logo = resolveCompanyLogo(article.company);
const topics = deriveTopics(article);
const entities = deriveEntities(article);
const minutes = readingMinutes(article);
const dateLabel = new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(new Date(article.published_at));
const seoDateLabel = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(new Date(article.published_at));
const shortDateFormatter = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" });

function cleanText(text: string): string {
  return text.replace(/\s+/g, " ").trim();
}

function truncateAtWord(text: string, maxLength: number): string {
  const clean = cleanText(text);
  if (clean.length <= maxLength) return clean;

  const clipped = clean.slice(0, Math.max(0, maxLength - 3));
  const lastSpace = clipped.lastIndexOf(" ");
  const base = lastSpace > 40 ? clipped.slice(0, lastSpace) : clipped;
  return `${base.trim()}...`;
}

function articlePageTitle(currentArticle: Article, currentDateLabel: string, includeDate: boolean): string {
  const suffix = includeDate
    ? ` | ${currentArticle.company} | ${currentDateLabel} | AI News Hub`
    : ` | ${currentArticle.company} | AI News Hub`;
  const minTitleLength = includeDate ? 24 : 32;
  const titleBudget = Math.max(minTitleLength, 60 - suffix.length);
  return `${truncateAtWord(currentArticle.title, titleBudget)}${suffix}`;
}

function articleMetaDescription(currentArticle: Article, currentExcerpt: string, currentDateLabel: string): string {
  const placeholderExcerpt = currentExcerpt.toLowerCase() === "no content.";
  const sourceText =
    !currentExcerpt || placeholderExcerpt
      ? `${currentArticle.company} release ${currentArticle.title} published ${currentDateLabel}.`
      : currentExcerpt;
  return truncateAtWord(
    `${sourceText} Linked by AI News Hub with source, date, publisher context, and the original article preserved for verification.`,
    155,
  );
}

function articlePath(currentArticle: Article): string {
  return `/article/${currentArticle.id}/`;
}

function absoluteArticleUrl(currentArticle: Article): string {
  return `${siteUrl}${articlePath(currentArticle)}`;
}

function articleTimestamp(currentArticle: Article): number {
  const time = new Date(currentArticle.published_at).getTime();
  return Number.isNaN(time) ? 0 : time;
}

function shortDate(value: string): string {
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? "Undated" : shortDateFormatter.format(date);
}

const excerpt = cleanText(article.summary || article.content || "");
const defaultTitleCounts = new Map<string, number>();
for (const currentArticle of allArticles) {
  const defaultTitle = articlePageTitle(currentArticle, "", false);
  defaultTitleCounts.set(defaultTitle, (defaultTitleCounts.get(defaultTitle) ?? 0) + 1);
}
const defaultTitle = articlePageTitle(article, "", false);
const includeDateInTitle = (defaultTitleCounts.get(defaultTitle) ?? 0) > 1;
const description = articleMetaDescription(article, excerpt, seoDateLabel);
const title = articlePageTitle(article, seoDateLabel, includeDateInTitle);
const articleTimeline = [...allArticles].sort((a, b) => articleTimestamp(b) - articleTimestamp(a));
const currentArticleIndex = articleTimeline.findIndex((currentArticle) => currentArticle.id === article.id);
const relatedArticleIds = new Set<string>();
const nearbyArticles = [-2, -1, 1, 2]
  .map((offset) => {
    if (currentArticleIndex < 0 || articleTimeline.length < 2) return null;
    const index = (currentArticleIndex + offset + articleTimeline.length) % articleTimeline.length;
    return articleTimeline[index] ?? null;
  })
  .filter((currentArticle): currentArticle is Article => {
    if (!currentArticle || currentArticle.id === article.id || relatedArticleIds.has(currentArticle.id)) {
      return false;
    }
    relatedArticleIds.add(currentArticle.id);
    return true;
  });

const structuredData = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: article.title,
  datePublished: article.published_at,
  dateModified: article.published_at,
  url: canonicalUrl,
  image: [socialImage],
  ...(originalUrl ? { isBasedOn: originalUrl } : {}),
  description,
  ...(topics.length ? { keywords: topics.map(topicLabel).join(", ") } : {}),
  author: { "@type": "Organization", name: article.company },
  ...(nearbyArticles.length ? { relatedLink: nearbyArticles.map(absoluteArticleUrl) } : {}),
  publisher: {
    "@type": "Organization",
    name: "AI News Hub",
    url: siteUrl,
    logo: { "@type": "ImageObject", url: socialImage },
  },
  mainEntityOfPage: canonicalUrl,
  isPartOf: { "@type": "WebSite", name: "AI News Hub", url: siteUrl },
};
---

<Layout
  title={title}
  description={description}
  canonical={canonicalUrl}
  ogType="article"
  structuredData={structuredData}
  preloadImages={logo ? [logo] : []}
>
  <main id="main-content" class="industrial-shell flex-1">
    <article class="industrial-container max-w-3xl py-12 md:py-16 reveal-stagger">
      <a href="/" class="micro-label inline-flex items-center gap-2 text-text-2 transition-colors hover:text-white focus-industrial">← Back to the feed</a>

      <div class="mt-8 flex items-center gap-3 border-b border-white/15 pb-5">
        {logo && (
          <span class="flex h-11 w-11 shrink-0 items-center justify-center border border-white/20 bg-white">
            <img src={logo} alt={companyLogoAlt(article.company)} width="32" height="32" class="h-8 w-8 object-contain" loading="eager" decoding="async" fetchpriority="high" />
          </span>
        )}
        <div>
          <p class="micro-label text-white">{article.company}</p>
          <time class="micro-label tabular-nums text-text-2" datetime={article.published_at}>{dateLabel}</time>
        </div>
      </div>

      <h1 class="mt-8 text-3xl font-black leading-tight text-white md:text-5xl text-pretty">{article.title}</h1>

      <div class="mt-5 flex flex-wrap items-center gap-x-2 gap-y-2 font-mono text-xs uppercase tracking-[0.06em] text-text-2">
        {domain && <span class="border border-white/20 px-2 py-1 text-white">{domain}</span>}
        {topics.map((key) => (
          <span class="border border-white/15 px-2 py-1">{topicLabel(key)}</span>
        ))}
        {entities.map((entity) => (
          <span class="border border-brand/40 px-2 py-1 text-brand-hover">{entity}</span>
        ))}
        {minutes > 0 && <span class="border border-white/15 px-2 py-1 tabular-nums">{minutes} min read</span>}
      </div>

      {excerpt && (
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-text-2 text-pretty">{excerpt}</p>
      )}

      {originalUrl && (
        <div class="mt-10">
          <a class="signal-button" href={originalUrl} target="_blank" rel="noopener noreferrer">
            Read the original on {domain || "the source"}
          </a>
        </div>
      )}

      <p class="micro-label mt-10 max-w-2xl leading-relaxed text-muted">
        AI News Hub links to primary sources. This page shows the publisher&apos;s own title and excerpt with a link to the full article. We point you at the news; we don&apos;t rewrite it.
      </p>

      {nearbyArticles.length > 0 && (
        <nav class="mt-10 border-t border-white/15 pt-6" aria-label="More AI News Hub source pages">
          <h2 class="micro-label text-text-2">More source pages</h2>
          <ul class="mt-4 space-y-3">
            {nearbyArticles.map((relatedArticle) => (
              <li>
                <a href={articlePath(relatedArticle)} class="block border border-white/15 p-3 transition-colors hover:border-brand/60 focus-industrial">
                  <span class="micro-label text-brand-hover">{relatedArticle.company}</span>
                  <span class="mt-1 block text-sm font-bold leading-snug text-white text-pretty">{relatedArticle.title}</span>
                  <time class="micro-label mt-1 block text-text-2" datetime={relatedArticle.published_at}>{shortDate(relatedArticle.published_at)}</time>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}
    </article>
  </main>
</Layout>
