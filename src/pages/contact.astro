---
import Layout from "../layouts/Layout.astro";

const siteUrl = "https://ai-news.helloworldfirm.com";
const canonicalUrl = `${siteUrl}/contact/`;
const title = "Contact AI News Hub and Hello.World Consulting";
const description =
  "Contact AI News Hub about source coverage, feed issues, AI research updates, provider additions and Hello.World Consulting maintenance.";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: title,
  url: canonicalUrl,
  description,
  author: {
    "@type": "Person",
    name: "Jonathan R Reed",
    url: "https://jonathanrreed.com",
  },
  datePublished: "2026-04-21",
  dateModified: "2026-04-21",
  isPartOf: {
    "@type": "WebSite",
    name: "AI News Hub",
    url: siteUrl,
  },
};
---

<Layout
  title={title}
  description={description}
  canonical={canonicalUrl}
  robots="index, follow, max-image-preview:large"
  structuredData={structuredData}
>
  <main id="main-content" class="industrial-shell flex-1">
    <section class="industrial-container py-24 md:py-36">
      <div class="max-w-5xl reveal-stagger">
        <p class="micro-label mb-5 text-brand-hover">[ Contact ]</p>
        <h1 class="macro-heading max-w-5xl">Contact AI News Hub</h1>
        <div class="mt-8 max-w-4xl space-y-5 text-lg leading-relaxed text-text-2">
          <p>
            Reach out about missing source feeds, broken provider links, stale AI research
            updates, source attribution, accessibility issues or potential additions to the AI
            News Hub provider list.
          </p>
          <p>
            The best provider suggestions include the organization name, the official RSS or Atom
            feed URL, the public blog or research page, and a short note about why the source is
            useful for builders who follow model releases, AI infrastructure, agent tooling,
            safety research or deployment guidance.
          </p>
          <p>
            AI News Hub is maintained by Hello.World Consulting as a practical monitoring surface.
            It is not a paid placement product, and inclusion depends on whether the
            organization provides stable public updates that fit the feed.
          </p>
          <p>
            For consulting work connected to private AI systems, local LLM deployment, retrieval
            architecture or AI security review, contact Hello.World Consulting through the main
            firm website.
          </p>
          <p>
            Bug reports are most useful when they include the page URL, browser, device, the
            action that failed and whether the problem happens after a hard refresh. For article
            data issues, include the affected company name and original publisher URL when
            possible.
          </p>
          <p>
            Accessibility feedback is welcome. The interface is meant to be keyboard reachable,
            readable in dark mode and usable on small screens, so reports about focus order,
            contrast, labels or layout shifts are treated as maintenance issues.
          </p>
        </div>
        <div class="mt-10 flex flex-wrap gap-4">
          <a class="signal-button" href="https://helloworldfirm.com/contact/">
            Contact Hello.World Consulting
          </a>
          <a class="signal-button" href="/">
            Back to the feed
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
