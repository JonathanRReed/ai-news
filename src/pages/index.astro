---
import Layout from "../layouts/Layout.astro";
import ArticlesIslandWrapper from "../components/ArticlesIslandWrapper.tsx";
import providerArticles from "../../public/data/provider-articles.json";
import { digestWeeks } from "../lib/digest.js";
import type { Article } from "../types/article.js";

const latestDigest = digestWeeks()[0];

const siteUrl = "https://ai-news.helloworldfirm.com";
const canonicalUrl = `${siteUrl}/`;
const title = "AI News Hub | Primary-Source AI News Feed";
const description =
  "AI News Hub tracks official AI lab, model-provider, and infrastructure posts in one searchable feed. It links to the source and does not rewrite the news.";
const keywords =
  "AI news, artificial intelligence news, AI research updates, OpenAI news, Anthropic updates, Google DeepMind announcements, Mistral AI, Hugging Face, Meta AI, xAI, DeepSeek, IBM Research, Amazon AI, NVIDIA AI, Alibaba Qwen";
const socialImage = `${siteUrl}/ai-news-favicon-512x512.png`;
const providerRows = providerArticles as Array<{ company: string; published_at: string; source_type?: string }>;
const cachedArticleCount = providerRows.length;
const cachedCompanyCount = new Set(providerRows.map((article) => article.company)).size;
const nowMs = Date.now();
const latestCacheDate = providerRows
  .map((article) => new Date(article.published_at).getTime())
  .filter((time) => Number.isFinite(time))
  .sort((a, b) => b - a)[0];
const latestCacheIso = latestCacheDate ? new Date(latestCacheDate).toISOString() : new Date(nowMs).toISOString();
// Absolute date, not a relative label: this is static HTML that only rebuilds when the
// cache changes, so a relative value would go stale (and lie) on quiet days.
const newestLabel = latestCacheDate
  ? new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(new Date(latestCacheDate))
  : "No date";
// Anchor "this week" to the newest story (data-derived), not the build clock, so the
// count stays correct between rebuilds and never drifts on code-only deploys.
const weekAnchor = latestCacheDate ?? nowMs;
const storiesThisWeek = providerRows.filter((article) => {
  const time = new Date(article.published_at).getTime();
  return Number.isFinite(time) && time > weekAnchor - 7 * 86400000;
}).length;
// Seed the first 20 (content stripped to keep the HTML lean) so the island renders
// server-side for crawlers and first paint, then refetches full data on the client.
const initialArticles: Article[] = (providerArticles as Article[])
  .slice()
  .sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime())
  .slice(0, 20)
  .map((a) => ({
    id: a.id,
    company: a.company,
    title: a.title,
    url: a.url,
    published_at: a.published_at,
    source_type: a.source_type,
    summary: a.summary ?? "",
  }));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "AI News Hub",
  url: siteUrl,
  description,
  creator: {
    "@type": "Person",
    name: "Jonathan R. Reed",
    url: "https://jonathanrreed.com",
    sameAs: [
      "https://github.com/JonathanRReed",
      "https://helloworldfirm.com",
    ],
  },
  publisher: {
    "@type": "Organization",
    name: "Hello.World Consulting",
    url: "https://helloworldfirm.com",
    logo: {
      "@type": "ImageObject",
      url: socialImage,
    },
  },
};

const collectionStructuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: siteUrl,
  author: {
    "@type": "Person",
    name: "Jonathan R. Reed",
    url: "https://jonathanrreed.com",
    sameAs: [
      "https://github.com/JonathanRReed",
      "https://helloworldfirm.com",
    ],
  },
  datePublished: "2026-04-21",
  dateModified: latestCacheIso.slice(0, 10),
  isPartOf: {
    "@type": "WebSite",
    name: "AI News Hub",
    url: siteUrl,
  },
};
---

<Layout
  title={title}
  description={description}
  canonical={canonicalUrl}
  keywords={keywords}
  currentPage="home"
  bodyClass="bg-bg-0 text-text-1 font-sans"
  structuredData={[structuredData, collectionStructuredData]}
>
  <main id="main-content" class="industrial-shell">
    <section class="industrial-container py-10 md:py-14">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_420px] lg:items-end reveal-stagger">
        <div class="max-w-5xl">
          <p class="micro-label mb-5 text-brand-hover">[ Primary sources only ]</p>
          <h1 class="macro-heading max-w-5xl">
            Primary-source AI news, releases and research in one fast feed.
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-2 md:text-xl">
            Every major AI lab, model provider and research team in one place: official posts only,
            linked straight to the source. We point you at the news; we don't rewrite it.
          </p>
        </div>
        <aside class="industrial-border p-5">
          <p class="micro-label mb-4 text-text-2">At a glance</p>
          <dl class="grid grid-cols-2 gap-px bg-white/15">
            <div class="bg-bg-0 p-4">
              <dt class="micro-label text-text-2">Labs tracked</dt>
              <dd class="mt-2 font-mono text-2xl font-black tabular-nums text-white">{cachedCompanyCount}</dd>
            </div>
            <div class="bg-bg-0 p-4">
              <dt class="micro-label text-text-2">Stories</dt>
              <dd class="mt-2 font-mono text-2xl font-black tabular-nums text-white">{cachedArticleCount}</dd>
            </div>
            <div class="bg-bg-0 p-4">
              <dt class="micro-label text-text-2">New this week</dt>
              <dd class="mt-2 font-mono text-2xl font-black tabular-nums text-white">{storiesThisWeek}</dd>
            </div>
            <div class="bg-bg-0 p-4">
              <dt class="micro-label text-text-2">Newest story</dt>
              <dd class="mt-2 font-mono text-lg font-black tabular-nums text-white">{newestLabel}</dd>
            </div>
          </dl>
          <p class="micro-label mt-4 text-muted">Sources checked daily</p>
        </aside>
      </div>
    </section>
    {latestDigest && (
      <section class="industrial-container pb-2">
        <div class="industrial-border reveal-stagger p-6 md:p-8">
          <div class="flex flex-wrap items-baseline justify-between gap-3 border-b border-white/15 pb-4">
            <h2 class="micro-label text-brand-hover">This week in AI</h2>
            <a
              href="/digest/"
              class="micro-label text-text-2 underline decoration-brand decoration-2 underline-offset-4 transition-colors hover:text-white focus-industrial"
            >
              See the full digest →
            </a>
          </div>
          <ol class="mt-4 space-y-3">
            {latestDigest.topStories.slice(0, 3).map((article, index) => (
              <li class="grid grid-cols-[auto_minmax(0,1fr)] gap-3">
                <span class="font-mono text-sm tabular-nums text-muted">{String(index + 1).padStart(2, "0")}</span>
                <a
                  href={`/article/${article.id}/`}
                  class="leading-snug text-white decoration-brand decoration-2 underline-offset-4 transition-colors hover:text-brand-hover hover:underline focus-industrial text-pretty"
                >
                  <span class="micro-label mr-2 text-text-2">{article.company}</span>{article.title}
                </a>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )}
    <section id="articles" class="industrial-container space-y-8 py-8 md:py-12">
      <ArticlesIslandWrapper client:load initialArticles={initialArticles} now={nowMs} />
    </section>
  </main>
</Layout>
