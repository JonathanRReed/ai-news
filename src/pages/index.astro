---
import ArticlesIslandWrapper from "../components/ArticlesIslandWrapper.tsx";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import NeuralGrid from "../components/NeuralGrid.tsx";

const siteUrl = "https://ai-news.helloworldfirm.com";
const canonicalUrl = `${siteUrl}/`;
const title = "AI News Hub for Research Lab and Model Provider Updates";
const description =
  "AI News Hub tracks current articles, releases and research updates from major AI labs, infrastructure providers and model companies in one searchable feed.";
const socialImage = "https://img.helloworldfirm.com/logos/512x512-logo.avif";
const socialImageAlt = "AI News Hub logo";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "AI News Hub",
  url: siteUrl,
  description,
  creator: {
    "@type": "Person",
    name: "Jonathan R Reed",
    url: "https://jonathanrreed.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Hello.World Consulting",
    url: "https://helloworldfirm.com",
    logo: {
      "@type": "ImageObject",
      url: socialImage,
    },
  },
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${siteUrl}/?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};

const collectionStructuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: siteUrl,
  author: {
    "@type": "Person",
    name: "Jonathan R Reed",
    url: "https://jonathanrreed.com",
  },
  datePublished: "2026-04-21",
  dateModified: "2026-04-21",
  isPartOf: {
    "@type": "WebSite",
    name: "AI News Hub",
    url: siteUrl,
  },
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="AI news, artificial intelligence news, AI research updates, OpenAI news, Anthropic updates, Google DeepMind announcements, Mistral AI, Hugging Face, Meta AI, xAI, DeepSeek, IBM Research, Amazon AI, NVIDIA AI, Alibaba Qwen"
    />
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <meta name="author" content="Hello.World Consulting" />
    <meta name="application-name" content="AI News Hub" />
    <meta name="apple-mobile-web-app-title" content="AI News Hub" />
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="AI News Hub" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <link rel="apple-touch-icon" href="/favicon.webp" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="dns-prefetch" href="https://img.helloworldfirm.com" />
    <link rel="preconnect" href="https://fonts.helloworldfirm.com" />
    <link
      rel="preconnect"
      href="https://fonts.helloworldfirm.com"
      crossorigin
    />
    <link rel="preload" href="/global-font.css" as="style" />
    <link rel="preload" href="/global-animated-gradient.css" as="style" />
    <link rel="stylesheet" href="/global-font.css" />
    <link rel="stylesheet" href="/global-animated-gradient.css" />
    <link
      rel="preload"
      href="https://fonts.helloworldfirm.com/NebulaSans-Book.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="https://fonts.helloworldfirm.com/NebulaSans-BoldItalic.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(collectionStructuredData)}
    />
    <script>
      (function () {
        if (typeof window === "undefined") return;
        const ascii = `
    ___  ________  ________     
   |\\  \\|\\   __  \\|\\   __  \\    
   \\ \\  \\ \\  \\|\\  \\ \\  \\|\\  \\   
 __ \\ \\  \\ \\   _  _\\ \\   _  _\\  
|\\  \\\\_\\  \\ \\  \\\\  \\\\ \\  \\\\  \\| 
\\ \\________\\ \\__\\\\ _\\\\ \\__\\\\ _\\ 
 \\|________|\\|__|\\|__|\\|__|\\|__|
        `;
        console.log(ascii);
        console.log("Source: https://github.com/JonathanRReed/ai-news");
      })();
    </script>
  </head>
  <body class="bg-bg-0 text-text-1 font-sans">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <NeuralGrid client:idle={{ timeout: 1800 }} />
    <Header currentPage="home" />
    <main id="main-content" class="industrial-shell">
      <section class="industrial-container py-10 md:py-14">
        <div class="max-w-5xl">
          <p class="micro-label mb-5 text-brand">[ AI source monitor ]</p>
          <h1 class="macro-heading max-w-5xl">
            AI News Hub tracks primary-source updates from major AI organizations.
          </h1>
          <details class="mt-6 max-w-3xl border border-brand/45 bg-bg-1/55 p-4 text-text-2">
            <summary class="cursor-pointer select-none font-mono text-xs font-black uppercase tracking-[0.16em] text-text-1">
              About this feed
            </summary>
            <div class="mt-4 grid gap-4 text-base leading-relaxed md:grid-cols-2">
              <p>
                The feed collects articles, release notes and research posts from model labs, cloud
                AI teams, infrastructure providers and open research organizations.
              </p>
              <p>
                Use the provider filters, search field and density controls to compare updates from
                OpenAI, Anthropic, Google DeepMind, Meta AI, Mistral AI, Hugging Face, xAI, DeepSeek,
                IBM Research, Amazon AI, NVIDIA AI and Alibaba Qwen.
              </p>
              <p>
                Each card keeps the source, publish date, title and summary close together so model
                launches, platform changes, safety research and infrastructure guidance are easier
                to scan.
              </p>
              <p>
                AI News Hub is maintained by Hello.World Consulting as a source-led monitoring
                surface for builders following model capability, deployment patterns, agent tooling,
                retrieval, security and local AI infrastructure.
              </p>
            </div>
          </details>
        </div>
      </section>
      <section id="articles" class="industrial-container space-y-8 py-8 md:py-12">
        <ArticlesIslandWrapper client:visible />
      </section>
    </main>
    <Footer />
  </body>
</html>
